];

const attended = [
  { when: "05/2025", title: "Socracan", location: "Las Palmas de Gran Canaria, Spain" },
  { when: "07/2022", title: "Tenerife GG", location: "Santa Cruz de Tenerife, Spain" },
  { when: "06/2022", title: "Pamplona Software Crafters", location: "Pamplona, Spain" },
  { when: "05/2022", title: "JSDay Canarias", location: "San Cristóbal de la La Laguna, Spain" },
  { when: "02/2020", title: "Socracan", location: "Santa Cruz de Tenerife, Spain" },
  { when: "11/2019", title: "NodeCONF EU", location: "Kilkenny, Ireland" },
  { when: "11/2019", title: "JSDay Canarias", location: "San Cristóbal de la La Laguna, Spain" },
  { when: "09/2019", title: "AdaLoversConf", location: "San Cristóbal de la La Laguna, Spain" },
  { when: "06/2019", title: "JSConf EU", location: "Berlin, Germany" },
  { when: "06/2019", title: "CSSconf EU", location: "Berlin, Germany" },
  { when: "05/2019", title: "React Europe", location: "Paris, France" },
  { when: "11/2018", title: "JSDay Canarias", location: "San Cristóbal de la La Laguna, Spain" },
  { when: "11/2018", title: "NodeCONF EU", location: "Kilkenny, Ireland" },
  { when: "06/2018", title: "JSConf EU", location: "Berlin, Germany" },
  { when: "04/2018", title: "Socracan", location: "Las Palmas de Gran Canaria, Spain" },
  { when: "11/2017", title: "JSDay Canarias", location: "Santa Cruz de Tenerife, Spain" },
