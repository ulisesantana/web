    position: "Higher Technician in Business Management and Marketing",
    from: "09/2011",
    to: "11/2012",
    description: [
      "Before entering the tech world, I completed a vocational course in business management and marketing covering customer management, logistics, sales, and reporting. This training gave me a strong understanding of how businesses operate, which has proven valuable when collaborating with stakeholders and understanding product goals.",
    ],
    skills: ["Marketing", "Customer management", "Logistics", "Sales", "Business management"],
