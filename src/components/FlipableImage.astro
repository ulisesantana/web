<style>
    .flipable-image {
        background-color: transparent;
        border: 4px solid var(--link-color);
        border-radius: 50%;
        flex-shrink: 0;
        height: 216px;
        margin: 0 auto;
        padding: 24px;
        perspective: 1000px;
        width: 216px;
    }

    .flipable-image img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 50%;
    }

    .flip-container {
        position: relative;
        width: 100%;
        height: 100%;
        text-align: center;
        transition: transform var(--transition-speed-regular);
        transform-style: preserve-3d;
    }

    .flipable-image:hover .flip-container,
    .flipable-image:active .flip-container {
        transform: rotateY(180deg);
    }

    .flipable-image:hover .flip-container .flip-front,
    .flipable-image:active .flip-container .flip-front {
        opacity: 0;
    }

    .flip-front,
    .flip-back {
        background-color: transparent;
        border-radius: 50%;
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
        transition: opacity ease-in-out var(--transition-speed-regular);
        will-change: transform;
    }

    .flip-back {
        opacity: 0;
        transform: rotateY(180deg);
    }

    .flipable-image:hover .flip-back,
    .flipable-image:active .flip-back {
        opacity: 1;
    }

    @media (max-width: 767px) {
        .flipable-image {
            width: 180px;
            height: 180px;
            padding: 20px;
            margin-bottom: 20px;
        }
    }
</style>

<div class="flipable-image">
  <div class="flip-container">
    <div class="flip-front">
      <slot name="front-image" />
    </div>
    <div class="flip-back no-print">
      <slot name="back-image" />
    </div>
  </div>
</div>
