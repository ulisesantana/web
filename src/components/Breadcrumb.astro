---
import { getLanguageFromPath } from "@/utils/getLanguageFromPath";
import { t } from "@/config/i18n";

const locale = getLanguageFromPath(Astro.url.pathname);
const homeHref = locale === "es" ? "/es" : "/";

// Remove current url path and remove trailing slash if exists
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Strip the /es prefix for breadcrumb segment parsing
const pathForBreadcrumb = locale === "es"
  ? currentUrlPath.replace(/^\/es/, "") || "/"
  : currentUrlPath;

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = pathForBreadcrumb.split("/").slice(1);

// if breadcrumb is Home > Posts > 1 <etc>
// replace Posts with Posts (page number)
if (breadcrumbList[0] === "posts") {
  breadcrumbList.splice(0, 2, `Posts (page ${breadcrumbList[1] || 1})`);
}

// if breadcrumb is Home > Tags > [tag] > [page] <etc>
// replace [tag] > [page] with [tag] (page number)
if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  breadcrumbList.splice(
    1,
    3,
    `${breadcrumbList[1]} ${Number(breadcrumbList[2]) === 1 ? "" : "(page " + breadcrumbList[2] + ")"}`
  );
}

// Build segment URLs relative to the locale root
const segmentBase = locale === "es" ? "/es" : "";

// Humanize a URL segment: replace hyphens with spaces and capitalize first letter
// e.g. "sobre-mi" → "Sobre mi", "about" → "About"
function humanize(segment: string): string {
  return decodeURIComponent(segment).replace(/-/g, " ").replace(/^\w/, c => c.toUpperCase());
}
---

<nav class="mx-auto mt-8 mb-1 w-full max-w-3xl px-4" aria-label="breadcrumb">
  <ul
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a href={homeHref} class="opacity-80">{t(locale, "home")}</a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class:list={["capitalize opacity-75", { lowercase: index > 0 }]}
              aria-current="page"
            >
              {humanize(breadcrumb)}
            </span>
          </li>
        ) : (
          <li>
            <a href={`${segmentBase}/${breadcrumb}/`} class="capitalize opacity-70">
              {humanize(breadcrumb)}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        )
      )
    }
  </ul>
</nav>
