---
import Socials from "./Socials.astro";
import FlipableImage from "./FlipableImage.astro";
import authorImg from "@/assets/images/about/author.jpg";
import logo from "@/assets/images/logo.png";
import type { Language } from "@/types";
export interface Props {
  locale: Language;
}
const locale = Astro.props.locale || "en";
const isSpanish = locale === "es";
---

<section class="author-info">
  <a href={isSpanish ? "/es" : "/"}>
    <FlipableImage>
      <img
        slot="front-image"
        src={authorImg.src}
        style="border-radius: 50%;"
        alt="Ulises Santana"
      />
      <img
        slot="back-image"
        src={logo.src}
        alt="Ulises Santana"
      />
    </FlipableImage>
  </a>
  <div class="info">
    <h2 class="title">
      {
        isSpanish ? (
          <span>
            👋 Hola! Soy <b>Ulises Santana</b>
          </span>
        ) : (
          <span>
            👋 Hi! I'm <b>Ulises Santana</b>
          </span>
        )
      }
    </h2>
    <p class="description">
      {
        isSpanish ? (
          <span>
            Me gano la vida como Desarrollador Full Stack. JavaScript es mi lengua
            materna y la web mi patria. Trasteo con tecnologías desde las Islas
            Canarias 🏝️
          </span>
        ) : (
          <span>
            Full Stack Developer with JavaScript as mother tongue and web as my home
            nation. Based in the Canary Islands 🏝️
          </span>
        )
      }
    </p>
    <Socials/>
  </div>
</section>

<style>
  b {
    color: var(--link-color);
    display: inline-block;
  }

  .author-info {
    align-items: center;
    display: flex;
    margin: 1rem auto;
    max-width: 768px;
    padding: 0 24px;
    width: 80ch;
  }

  .description {
    font-size: var(--font-size-1);
    line-height: var(--line-height-normal-text);
    margin: 0;
    text-align: justify;
  }

  .info {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-left: 30px;
  }

  .title {
    font-size: var(--font-size-3);
    font-weight: 400;
    font-family: var(--font-family-1);
    margin: 0;
  }

  @media (max-width: 767px) {
    .author-info {
      padding: 0 25px;
    }

    .info {
      gap: 0.5rem;
    }

    .description {
      font-size: var(--font-size-1);
      line-height: var(--line-height-normal-text);
      margin: 1rem auto;
    }
  }

  @media (max-width: 575px) {
    .author-info {
      display: block;
      text-align: center;
    }

    .info {
      align-items: center;
      padding-left: 0;
    }

    .description {
      text-align: justify;
    }
  }
</style>
