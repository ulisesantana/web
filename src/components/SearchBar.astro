---
import { t, type Locale } from "@/config/i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const searchUrl = locale === "es" ? "/es/search" : "/search";
---

<form
  action={searchUrl}
  method="GET"
  role="search"
  class="relative mb-6"
>
  <label for="page-search" class="sr-only">{t(locale, "searchTitle")}</label>
  <input
    id="page-search"
    type="search"
    name="q"
    placeholder={t(locale, "searchDesc")}
    class="w-full rounded border border-border bg-background px-4 py-2 pr-12 text-foreground placeholder:italic placeholder:opacity-60 focus:outline-none focus:ring-2 focus:ring-accent"
  />
  <button
    type="submit"
    aria-label={t(locale, "searchTitle")}
    class="absolute right-2 top-1/2 -translate-y-1/2 p-1 text-accent opacity-80 hover:opacity-100 focus:outline-none"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path stroke="none" d="M0 0h24v24H0z" fill="none" />
      <path d="M10 10m-7 0a7 7 0 1 0 14 0a7 7 0 1 0 -14 0" />
      <path d="M21 21l-6 -6" />
    </svg>
  </button>
</form>
