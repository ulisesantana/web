---
export interface Props {
  /** Explicit URL for the translated version of the current page.
   *  When provided it takes precedence over the pathname-toggle heuristic. */
  translatedUrl?: string;
}

const { translatedUrl } = Astro.props;
const { pathname } = Astro.url;
const isSpanish = pathname.startsWith('/es');
let targetPath = '';
let emoji = '';
if (isSpanish) {
  // Switch to English: remove '/es' prefix or use provided URL
  targetPath = translatedUrl ?? (pathname.replace(/^\/es/, '') || '/');
  emoji = '🇬🇧';
} else {
  // Switch to Spanish: add '/es' prefix or use provided URL
  targetPath = translatedUrl ?? ('/es' + (pathname === '/' ? '' : pathname));
  emoji = '🇪🇸';
}
---
<style>
  a {
    background: none;
    border: none;
    font-size: 2rem;
    cursor: pointer;
    height: 2rem;
  }
</style>

<a
  aria-label={isSpanish ? 'Switch to English' : 'Cambiar a español'}
  href={targetPath}
>
  {emoji}
</a>

