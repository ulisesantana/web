---
const { pathname } = Astro.url;
const isSpanish = pathname.startsWith('/es');
let targetPath = '';
let emoji = '';
if (isSpanish) {
  // Cambiar a inglés: quitar '/es' del principio
  targetPath = pathname.replace(/^\/es/, '') || '/';
  emoji = '🇬🇧';
} else {
  // Cambiar a español: agregar '/es' al principio
  targetPath = '/es' + (pathname === '/' ? '' : pathname);
  emoji = '🇪🇸';
}
---
<style>
  a {
    background: none;
    border: none;
    font-size: 2rem;
    cursor: pointer;
    height: 2rem;
  }
</style>

<a
  aria-label={isSpanish ? 'Switch to English' : 'Cambiar a español'}
  href={targetPath}
>
  {emoji}
</a>

