---
import Hr from "./Hr.astro";
import Socials from "./Socials.astro";
import { getLanguageFromPath } from "@/utils/getLanguageFromPath";
import { t } from "@/config/i18n";

const currentYear = new Date().getFullYear();
const locale = getLanguageFromPath(Astro.url.pathname);

export interface Props {
  noMarginTop?: boolean;
}

const { noMarginTop = false } = Astro.props;
---
<footer class:list={["w-full", { "mt-auto": !noMarginTop }]}>
  <Hr noPadding />
  <div
    class="flex flex-col items-center justify-between pt-6 pb-28 sm:pt-4 sm:flex-row-reverse md:pb-4"
  >
    <Socials centered />
    <div class="my-2 flex flex-col items-center whitespace-nowrap sm:flex-row">
      <span>Copyright &#169; {currentYear}</span>
      <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
      <span>{t(locale, "allRightsReserved")}</span>
    </div>
  </div>
</footer>
