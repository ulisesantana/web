---
import type { Locale } from "@/config/i18n";
import en from "@/data/cv/en.yaml";
import es from "@/data/cv/es.yaml";

const { locale = "en" } = Astro.props as { locale?: Locale };
const { milestones } = locale === "es" ? es : en;
---

<section class="mb-12">
  <h2 class="mb-6 border-b pb-2 text-2xl font-semibold">
    {locale === "es" ? "Hitos" : "Milestones"}
  </h2>
  <ul class="space-y-6">
    {
      milestones.map((m: any) => (
        <li>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="font-semibold">{m.title}</h3>
            <span class="text-sm text-muted">{m.when}</span>
          </div>
          <p class="mt-1 text-sm leading-relaxed">{m.description}</p>
          {m.youtube && (
            <a
              href={`https://www.youtube.com/watch?v=${m.youtube}`}
              class="mt-1 inline-block text-xs text-accent underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              {locale === "es" ? "Ver en YouTube ↗" : "Watch on YouTube ↗"}
            </a>
          )}
        </li>
      ))
    }
  </ul>
</section>
