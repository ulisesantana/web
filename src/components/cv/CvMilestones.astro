---
import type { Locale } from "@/config/i18n";
import en from "@/data/cv/en.yaml";
import es from "@/data/cv/es.yaml";
import CvEntryHeader from "./CvEntryHeader.astro";
import CvSectionTitle from "./CvSectionTitle.astro";

const { locale = "en" } = Astro.props as { locale?: Locale };
const { milestones } = locale === "es" ? es : en;
---

<section id="milestones" class="mb-12">
  <CvSectionTitle title={locale === "es" ? "Hitos" : "Milestones"} />
  <ul class="list-none px-0">
    {
      milestones.map((m: any) => (
        <li class="px-0">
          <CvEntryHeader title={m.title} dateRange={m.when} small />
          <p class="mt-1 leading-relaxed">{m.description}</p>
          {m.youtube && (
            <a
              href={`https://www.youtube.com/watch?v=${m.youtube}`}
              class="mt-1 inline-block text-xs text-accent underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              {locale === "es" ? "Ver en YouTube ↗" : "Watch on YouTube ↗"}
            </a>
          )}
        </li>
      ))
    }
  </ul>
</section>
