---
import type { Locale } from "@/config/i18n";
import en from "@/data/cv/en.yaml";
import es from "@/data/cv/es.yaml";
import CvSkills from "./CvSkills.astro";
import CvEntryHeader from "./CvEntryHeader.astro";
import CvSectionTitle from "./CvSectionTitle.astro";

const { locale = "en" } = Astro.props as { locale?: Locale };
const { jobs } = locale === "es" ? es : en;
---

<section id="work-experience" class="mb-12 px-0">
  <CvSectionTitle title={locale === "es" ? "Experiencia" : "Experience"} />
  {
    jobs.map((job: any) => (
      <article>
        <CvEntryHeader
          title={job.position}
          subtitle={job.employer}
          dateRange={`${job.from} – ${job.to}`}
          location={job.location}
        />
        {job.description.map((p: string) => (
          <p class="mb-2 leading-relaxed">{p}</p>
        ))}
        <CvSkills skills={job.skills} />
      </article>
    ))
  }
</section>
