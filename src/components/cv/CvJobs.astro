---
import type { Locale } from "@/config/i18n";
import en from "@/data/cv/en.yaml";
import es from "@/data/cv/es.yaml";

const { locale = "en" } = Astro.props as { locale?: Locale };
const { jobs } = locale === "es" ? es : en;
---

<section class="mb-12">
  <h2 class="mb-6 border-b pb-2 text-2xl font-semibold">
    {locale === "es" ? "Experiencia" : "Experience"}
  </h2>
  {
    jobs.map((job: any) => (
      <article class="mb-8">
        <div class="flex flex-wrap items-baseline justify-between gap-x-4">
          <h3 class="text-lg font-bold">
            {job.position} · <span class="text-accent">{job.employer}</span>
          </h3>
          <span class="text-sm text-muted">
            {job.from} – {job.to}
          </span>
        </div>
        <p class="mb-2 text-sm italic text-muted">{job.location}</p>
        {job.description.map((p: string) => (
          <p class="mb-2 text-sm leading-relaxed">{p}</p>
        ))}
        <ul class="mt-3 flex flex-wrap gap-2">
          {job.skills.map((s: string) => (
            <li class="rounded bg-muted/30 px-2 py-0.5 text-xs">{s}</li>
          ))}
        </ul>
      </article>
    ))
  }
</section>
