---
import type { Locale } from "@/config/i18n";
import en from "@/data/cv/en.yaml";
import es from "@/data/cv/es.yaml";

const { locale = "en" } = Astro.props as { locale?: Locale };
const { sponsored, attended } = locale === "es" ? es : en;
---

<section class="mb-12">
  <h2 class="mb-6 border-b pb-2 text-2xl font-semibold">
    {locale === "es" ? "Eventos Patrocinados" : "Sponsored Events"}
  </h2>
  <ul class="space-y-2">
    {
      sponsored.map((e: any) => (
        <li class="flex flex-wrap justify-between gap-x-4 text-sm">
          <span class="font-medium">{e.title}</span>
          <span class="text-muted">
            {e.location} · {e.when}
          </span>
        </li>
      ))
    }
  </ul>
</section>

<section class="mb-12">
  <h2 class="mb-6 border-b pb-2 text-2xl font-semibold">
    {locale === "es" ? "Eventos Asistidos" : "Events Attended"}
  </h2>
  <ul class="space-y-2">
    {
      attended.map((e: any) => (
        <li class="flex flex-wrap justify-between gap-x-4 text-sm">
          <span class="font-medium">{e.title}</span>
          <span class="text-muted">
            {e.location} · {e.when}
          </span>
        </li>
      ))
    }
  </ul>
</section>
