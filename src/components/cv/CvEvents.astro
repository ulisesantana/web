---
import type { Locale } from "@/config/i18n";
import en from "@/data/cv/en.yaml";
import es from "@/data/cv/es.yaml";
import CvSectionTitle from "./CvSectionTitle.astro";

const { locale = "en" } = Astro.props as { locale?: Locale };
const { sponsored, attended } = locale === "es" ? es : en;
---

<section id="sponsored-events" class="mb-12">
  <CvSectionTitle title={locale === "es" ? "Eventos Patrocinados" : "Sponsored Events"} />
  <ul class="px-0">
    {
      sponsored.map((e: any) => (
        <li class="flex flex-wrap justify-between gap-x-4">
          <span class="font-medium">{e.title}</span>
          <span class="text-muted">
            {e.location} · {e.when}
          </span>
        </li>
      ))
    }
  </ul>
</section>

<section id="attended-events" class="mb-12">
  <CvSectionTitle title={locale === "es" ? "Eventos Asistidos" : "Events Attended"} />
  <ul class="px-0">
    {
      attended.map((e: any) => (
        <li class="flex flex-wrap justify-between gap-x-4">
          <span class="font-medium">{e.title}</span>
          <span class="text-muted">
            {e.location} · {e.when}
          </span>
        </li>
      ))
    }
  </ul>
</section>
