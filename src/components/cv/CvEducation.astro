---
import type { Locale } from "@/config/i18n";
import en from "@/data/cv/en.yaml";
import es from "@/data/cv/es.yaml";

const { locale = "en" } = Astro.props as { locale?: Locale };
const { education } = locale === "es" ? es : en;
---

<section class="mb-12">
  <h2 class="mb-6 border-b border-dashed pb-2 text-2xl font-semibold">
    {locale === "es" ? "Formación" : "Education"}
  </h2>
  {
    education.map((edu: any) => (
      <article class="mb-8">
        <div class="flex flex-wrap items-baseline justify-between gap-x-4">
          <h3 class="text-lg font-bold">{edu.position}</h3>
          <span class="text-sm text-muted">
            {edu.from} – {edu.to}
          </span>
        </div>
        <p class="mb-2 text-sm italic text-muted">
          {edu.institution} · {edu.location}
        </p>
        {edu.description.map((p: string) => (
          <p class="mb-2 text-sm leading-relaxed">{p}</p>
        ))}
        <ul class="mt-3 flex flex-wrap gap-2">
          {edu.skills.map((s: string) => (
            <li class="rounded bg-muted/30 px-2 py-0.5 text-xs">{s}</li>
          ))}
        </ul>
      </article>
    ))
  }
</section>
