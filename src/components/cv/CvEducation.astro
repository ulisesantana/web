---
import type { Locale } from "@/config/i18n";
import en from "@/data/cv/en.yaml";
import es from "@/data/cv/es.yaml";
import CvSkills from "./CvSkills.astro";
import CvEntryHeader from "./CvEntryHeader.astro";
import CvSectionTitle from "./CvSectionTitle.astro";

const { locale = "en" } = Astro.props as { locale?: Locale };
const { education } = locale === "es" ? es : en;
---

<section class="mb-12">
  <CvSectionTitle title={locale === "es" ? "Formación" : "Education"} />
  {
    education.map((edu: any) => (
      <article class="mb-8">
        <CvEntryHeader
          title={edu.position}
          dateRange={`${edu.from} – ${edu.to}`}
          location={`${edu.institution} · ${edu.location}`}
        />
        {edu.description.map((p: string) => (
          <p class="mb-2 text-sm leading-relaxed">{p}</p>
        ))}
        <CvSkills skills={edu.skills} />
      </article>
    ))
  }
</section>
