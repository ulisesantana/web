---
import { ClientRouter } from "astro:transitions";
import { SITE } from "@/config";
import "@/styles/global.css";
import { getLanguageFromPath } from "@/utils/getLanguageFromPath";

const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

export interface Props {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  /**
   * URL of the translated version of this page.
   * - `string`    → explicit alternate URL (used by blog posts with a translation)
   * - `null`      → no alternate exists (untranslated post — omit hreflang alternate)
   * - `undefined` → auto-derive by flipping the `/es` prefix (listing pages, static pages)
   */
  alternateUrl?: string | null;
}

const lang = getLanguageFromPath(Astro.url.pathname);
const defaultDesc = lang === "es" ? SITE.descEs : SITE.desc;

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = defaultDesc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  alternateUrl,
} = Astro.props;

// Compute the alternate-language URL for hreflang tags.
// - Explicit string from the caller (post with a known translation URL)
// - null explicitly → no alternate (untranslated post)
// - undefined → auto-derive for listing / static pages by swapping the /es prefix
let hreflangAlternate: string | null;
if (alternateUrl === null) {
  hreflangAlternate = null;
} else if (typeof alternateUrl === "string") {
  hreflangAlternate = alternateUrl;
} else {
  // Auto-derive: flip /es prefix
  const pathname = Astro.url.pathname;
  hreflangAlternate =
    lang === "es"
      ? new URL(pathname.replace(/^\/es/, "") || "/", Astro.site).href
      : new URL(`/es${pathname}`, Astro.site).href;
}

// English URL is always the x-default
const hreflangEnUrl =
  lang === "en"
    ? canonicalURL.toString()
    : hreflangAlternate ?? canonicalURL.toString();
const hreflangEsUrl =
  lang === "es"
    ? canonicalURL.toString()
    : hreflangAlternate ?? null;

const socialImageURL = new URL(ogImage, Astro.url);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: `${title}`,
  image: `${socialImageURL}`,
  datePublished: `${pubDatetime?.toISOString()}`,
  ...(modDatetime && { dateModified: modDatetime.toISOString() }),
  author: [
    {
      "@type": "Person",
      name: `${author}`,
      ...(profile && { url: profile }),
    },
  ],
};
---

<!doctype html>
<html lang={lang} class={`${scrollSmooth && "scroll-smooth"}`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Sans:ital,wght@0,400;0,600;0,700;1,400&family=Fira+Code:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Google JSON-LD Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Enable RSS feed auto-discovery  -->
    <!-- https://docs.astro.build/en/recipes/rss/#enabling-rss-feed-auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL(getLanguageFromPath(Astro.url.pathname) === "es" ? "es/rss.xml" : "rss.xml", Astro.site)}
    />

    <!-- hreflang: link English and Spanish versions for SEO -->
    <link rel="alternate" hreflang="en" href={hreflangEnUrl} />
    {hreflangEsUrl && <link rel="alternate" hreflang="es" href={hreflangEsUrl} />}
    <link rel="alternate" hreflang="x-default" href={hreflangEnUrl} />

    <meta name="theme-color" content="" />

    {
      // If PUBLIC_GOOGLE_SITE_VERIFICATION is set in the environment variable,
      // include google-site-verification tag in the heading
      // Learn more: https://support.google.com/webmasters/answer/9008080#meta_tag_verification&zippy=%2Chtml-tag

      googleSiteVerification && (
        <meta
          name="google-site-verification"
          content={googleSiteVerification}
        />
      )
    }

    <ClientRouter />

    <script is:inline src="/globals.js"></script>
    <script is:inline src="/toggle-theme.js"></script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
